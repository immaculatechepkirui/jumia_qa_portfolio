          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/catalog/?q=phone&price=10000-30000",
              "host": ["{{base_url}}"],
              "path": ["catalog", ""],
              "query": [
                {
                  "key": "q",
                  "value": "phone"
