            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response body indicates no results', function () {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.satisfy(function(b) {",
                  "        return b.includes('No results') || b.includes('no results') || b.includes('0 results');",
                  "    }, 'Expected no-results message in response');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/catalog/?q=xyznonexistentproduct999abc",
              "host": ["{{base_url}}"],
              "path": ["catalog", ""],
              "query": [
                {
                  "key": "q",
                  "value": "xyznonexistentproduct999abc"
                }
              ]
            },
            "description": "TC-007: Search for a term that returns no results. Expects a no-results message."
          }
        },
        {
