{
  "info": {
    "name": "Jumia Kenya — API Tests",
    "description": "API test collection for Jumia Kenya (jumia.co.ke). Tests cover search, product catalog, product detail, cart, and navigation endpoints captured during exploratory testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://www.jumia.co.ke",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Search",
      "item": [
        {
          "name": "Search - Valid keyword (samsung)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});",
                  "",
                  "pm.test('Response contains HTML content', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
                  "});",
                  "",
                  "pm.test('Response body contains search term', function () {",
                  "    pm.expect(pm.response.text()).to.include('samsung');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/catalog/?q=samsung",
              "host": ["{{base_url}}"],
              "path": ["catalog", ""],
              "query": [
                {
                  "key": "q",
                  "value": "samsung"
                }
              ]
            },
            "description": "TC-005: Search for a valid keyword. Expects 200 response with relevant results."
          }
        },
        {
          "name": "Search - Empty keyword",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 302', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});",
                  "",
                  "pm.test('No server error returned', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/catalog/?q=",
              "host": ["{{base_url}}"],
              "path": ["catalog", ""],
              "query": [
                {
                  "key": "q",
                  "value": ""
                }
              ]
